{
  "name": "vocab-builder",
  "version": "1.0.0",
  "description": "每日单词学习，提升词汇量",
  "author": "小鬼",
  "commands": [
    {
      "pattern": "每日单词 (.+)",
      "action": "setDailyWord",
      "description": "设置每日单词语言"
    },
    {
      "pattern": "查单词 (.+)",
      "action": "lookupWord",
      "description": "查询单词详情"
    },
    {
      "pattern": "复习单词",
      "action": "reviewWords",
      "description": "复习学过的单词"
    },
    {
      "pattern": "测试我",
      "action": "quizUser",
      "description": "单词小测试"
    },
    {
      "pattern": "单词进度",
      "action": "showProgress",
      "description": "查看学习进度"
    }
  ],
  "config": {
    "language": "en",
    "level": 3,
    "dailyCount": 5,
    "notifyTime": "09:00"
  },
  "triggers": [
    {
      "type": "cron",
      "schedule": "0 9 * * *",
      "action": "sendDailyWord"
    }
  ]
}
