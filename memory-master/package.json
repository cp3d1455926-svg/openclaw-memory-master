{
  "name": "memory-master",
  "version": "4.1.0",
  "description": "AI 记忆系统 - 基于 Karpathy 方法论 + Anthropic 官方经验 + Claude Code 架构",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "view-memory": "cat memory/MEMORY.md",
    "compact": "node dist/cli/compact.js",
    "query": "node dist/cli/query.js",
    "memory-stats": "node dist/cli/stats.js",
    "export": "node dist/cli/export.js",
    "restore": "node dist/cli/restore.js",
    "curate": "ts-node scripts/curate-memory.ts",
    "curate:run": "node dist/scripts/curate-memory.js"
  },
  "keywords": [
    "memory",
    "ai",
    "agent",
    "karpathy",
    "anthropic",
    "claude",
    "openclaw"
